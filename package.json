{
  "name": "mailmind-ai-mono",
  "version": "1.0.0",
  "description": "Root workspace for MailMind AI",
  "private": true,
  "scripts": {
    "install-all": "npm install && npm --prefix server install && npm --prefix client install",
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "start": "concurrently \"npm run server\" \"npm run client\"",
    "server": "npm --prefix server run dev",
    "client": "npm --prefix client run dev",
    "build": "npm --prefix client install && npm --prefix client run build"
  },
  "devDependencies": {
    "concurrently": "^10.0.3"
  }
}